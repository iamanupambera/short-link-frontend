# Backend API base URL, including the API version prefix.
API_BASE_URL=http://localhost:3000/api/v1

# Public frontend URL used when composing absolute app links.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Public short-link redirect origin exposed to the browser for copy/share UI.
NEXT_PUBLIC_SHORT_URL_BASE=http://localhost:3000

# Used to encrypt the frontend httpOnly session cookie.
SESSION_SECRET=replace-with-at-least-32-random-characters
